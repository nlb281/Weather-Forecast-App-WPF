<Window x:Class="weatherApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:weatherApp.ViewModels"
        mc:Ignorable="d"
        Title="Weather App" Height="800" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style x:Key="ButtonWhiteStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Foreground" Value="#2196F3"/>
            <Setter Property="Background" Value="#ffffff"/>
        </Style>
        
        <Style x:Key="ButtonBlueStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="Background" Value="#2196F3"/>
        </Style>
    </Window.Resources>
    
    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#2196F3" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox Grid.Column="0" 
                         x:Name="CityTextBox"
                         Text="{Binding CityName}"
                         Background="White"
                         Foreground="#333333"
                         FontSize="16"
                         Padding="12,8"
                         BorderThickness="0"
                         Margin="0 0 10 0"
                         VerticalContentAlignment="Center"/>
                
                <Button
                        Grid.Column="1" 
                        Style="{StaticResource ButtonWhiteStyle}"
                        Content="Поиск"
                        Command="{Binding SearchWeatherCommand}"
                        CommandParameter="{Binding Text, ElementName=CityTextBox}"/>
            </Grid>
        </Border>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20">
                <Grid Margin="0 0 0 40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
    
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CityNameInXAML}"
                                   FontSize="28" 
                                   FontWeight="Bold"/>
        
                        <TextBlock Text="{Binding ConditionDisplay}" 
                                   FontSize="16" 
                                   Foreground="#666666"/>
                    </StackPanel>
    
                    <Button
                            Grid.Column="1" 
                            Style="{StaticResource ButtonBlueStyle}"
                            Content="В избранное"
                            Command="{Binding AddToFavoritesCommand}"/>
                </Grid>
                <Border Style="{StaticResource CardStyle}" Background="#E3F2FD">
                    <StackPanel>
                        <TextBlock Text="ТЕМПЕРАТУРА" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Temperature, StringFormat={}{0}°C}" 
                                   FontSize="64" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding FeelsLike, StringFormat={}Ощущается как {0}°C}" 
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                
                <Grid Margin="0,0,0,40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,5,5">
                        <StackPanel>
                            <TextBlock Text="ВЛАЖНОСТЬ" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding Humidity, StringFormat={}{0}%}" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardStyle}" Margin="5,0,0,5">
                        <StackPanel>
                            <TextBlock Text="ДАВЛЕНИЕ" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding Pressure, StringFormat={}{0} мм рт. ст.}" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,5,5,0">
                        <StackPanel>
                            <TextBlock Text="ВЕТЕР" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding WindSpeed, StringFormat={}{0} м/с}" Style="{StaticResource ValueStyle}"/>
                        </StackPanel>
                    </Border>
                    
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}" Margin="5,5,0,0">
                        <StackPanel>
                            <TextBlock Text="СОСТОЯНИЕ" Style="{StaticResource LabelStyle}"/>
                            <TextBlock Text="{Binding ConditionDisplay}"
                                       Style="{StaticResource ValueStyle}"
                                       FontSize="18"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
                <Button 
                    Style="{StaticResource ButtonBlueStyle}"
                    Content="Избранное"
                    Command="{Binding ShowFavoritesCommand}"
                    ></Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>